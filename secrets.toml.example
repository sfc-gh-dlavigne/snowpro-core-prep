# Copy this file to .streamlit/secrets.toml and fill in your credentials.
# Required for running locally without a ~/.snowflake/connections.toml entry.
# NOT needed when running inside Streamlit in Snowflake (SiS).

[connections.snowflake]
account   = "your-account-locator"   # e.g. "xy12345.us-east-1"
user      = "your_username"
password  = "your_password"          # or use private_key_path below
role      = "SYSADMIN"               # any role with CORTEX usage privilege
warehouse = "COMPUTE_WH"
database  = "SNOWFLAKE"
schema    = "PUBLIC"

# Alternatively, use key-pair auth:
# private_key_path = "/path/to/rsa_key.p8"

# ---------------------------------------------------------------------------
# NOT this file: if you'd rather use a named connection in
# ~/.snowflake/connections.toml, select it with an environment variable:
#     export SNOWFLAKE_CONNECTION_NAME=<your-connection-name>
# The connection name does NOT go in secrets.toml.
# ---------------------------------------------------------------------------
